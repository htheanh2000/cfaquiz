# Copy to .env and fill values
# Database (Postgres - use same as docker-compose or external)
DATABASE_URL=postgresql://postgres:password@localhost:5432/cfaquiz
DB_NAME=cfaquiz

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Cloudinary (optional, for uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
